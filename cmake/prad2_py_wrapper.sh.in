#!/bin/sh
# prad2evviewer Python-tool wrapper — generated by CMake.
#
# Resolves <prefix> from the wrapper's own location and sets the env
# needed to import prad2py + locate database/resources before running
# the target Python script.  Sourcing setup.sh is NOT required.

case "$0" in
    /*)   _self="$0" ;;
    */*)  _self="$PWD/$0" ;;
    *)    _self="$(command -v "$0" 2>/dev/null || printf '%s\n' "$0")" ;;
esac
_wrap_dir="$(cd "$(dirname "$_self")/.." && pwd)"
unset _self

: "${PRAD2_DATABASE_DIR:=${_wrap_dir}/share/prad2evviewer/database}"
: "${PRAD2_RESOURCE_DIR:=${_wrap_dir}/share/prad2evviewer/resources}"
export PRAD2_DATABASE_DIR PRAD2_RESOURCE_DIR

export PYTHONPATH="${_wrap_dir}/lib/prad2py${PYTHONPATH:+:$PYTHONPATH}"

exec python3 "${_wrap_dir}/share/prad2evviewer/scripts/@PRAD2_WRAPPER_SCRIPT_REL@" "$@"
