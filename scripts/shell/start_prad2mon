#!/bin/tcsh -f
# ───────────────────────────────────────────────────────────────────────
# prad2_server_tmux_template — launch prad2_server inside a detached
# tmux session with stdout/stderr tee'd to a console log so crashes
# leave a trail.
#
# Template — NOT installed by `make install`.  Copy it to a convenient
# location (e.g. ~/bin/prad2_server_tmux.csh), tweak the config block
# for your site, and `chmod +x` the copy.
#
# Prerequisite: source prad2_setup.csh first so prad2_server is on PATH
# and LD_LIBRARY_PATH picks up the installed shared libraries (evio, …).
# ───────────────────────────────────────────────────────────────────────

# ── Site-specific config — edit these for your setup ───────────────────
set HOST_MACHINE = "clondaq6"
set SESSION      = "prad2mon"
set LOG_DIR      = "/home/clasrun/prad2_daq/monitor"
set LOG          = "$LOG_DIR/console.log"
set SERVER_ARGS  = "--et -d /data/stage6"

# ── Remote dispatch: bounce to $HOST_MACHINE if we're elsewhere ────────
# Assumes the script path ($0) resolves on the target host too — true
# on JLab hall setups where /home is NFS-mounted across the cluster.
set THIS_HOST = `hostname -s`
if ( "$THIS_HOST" != "$HOST_MACHINE" ) then
    echo "Not on ${HOST_MACHINE} (this is ${THIS_HOST}) — forwarding via ssh…"
    exec ssh -t $HOST_MACHINE "$0" $argv:q
endif

# ── Pre-flight checks ──────────────────────────────────────────────────
tmux has-session -t $SESSION >& /dev/null
if ( $status == 0 ) then
    echo "tmux session '$SESSION' is already running."
    echo "  attach:  tmux attach -t $SESSION"
    echo "  kill:    tmux kill-session -t $SESSION"
    exit 1
endif

which prad2_server >& /dev/null
if ( $status != 0 ) then
    echo "prad2_server not on PATH — source prad2_setup.csh first." >& /dev/stderr
    exit 1
endif

mkdir -p "$LOG_DIR"

# ── Build the sh command that will run inside tmux ─────────────────────
# Single-quoted pieces are passed literally to sh (so it evaluates
# $(date)); double-quoted pieces are expanded by tcsh so $LOG_DIR etc.
# substitute at launch time.
#
#   stdbuf -oL -eL   line-buffer stdout/stderr so tee flushes every line,
#                    even if the server crashes mid-buffer.
#   2>&1 | tee -a    merge stderr, persist to $LOG, still visible in pane.
#   echo '--- ...'   stamp a clean exit or crash in the log with a date.
#   exec bash        keep the pane alive after the server dies so you can
#                    `tmux attach` and see the last output before it goes.
set SH_CMD = "stdbuf -oL -eL prad2_server ${SERVER_ARGS} 2>&1 | tee -a ${LOG}"
set SH_CMD = "${SH_CMD}"'; echo "--- prad2_server exited at $(date) ---" >> '"${LOG}"
set SH_CMD = "${SH_CMD}"'; exec bash'

tmux new-session -d -s $SESSION sh -c "$SH_CMD"

if ( $status == 0 ) then
    echo "Started tmux session '$SESSION'."
    echo "  attach:  tmux attach -t $SESSION"
    echo "  tail:    tail -f $LOG"
    echo "  stop:    tmux send-keys -t $SESSION C-c"
else
    echo "Failed to start tmux session." >& /dev/stderr
    exit 1
endif

# ───────────────────────────────────────────────────────────────────────
# Log rotation (optional — run via cron, or drop into /etc/logrotate.d/)
#
# Root-owned install (as /etc/logrotate.d/prad2_server):
#
#   /home/clasrun/prad2_daq/monitor/console.log {
#       daily
#       rotate 14
#       missingok
#       notifempty
#       compress
#       delaycompress
#       copytruncate
#       su clasrun clasrun
#   }
#
# User-level (~/logrotate.prad2_server.conf, driven by a crontab entry):
#
#   /home/clasrun/prad2_daq/monitor/console.log {
#       daily
#       rotate 14
#       missingok
#       notifempty
#       compress
#       delaycompress
#       copytruncate
#   }
#
# Crontab:
#   5 0 * * * /usr/sbin/logrotate --state $HOME/.logrotate.state \
#             $HOME/logrotate.prad2_server.conf
#
# copytruncate keeps the file descriptor tee is holding valid, so no
# server restart is needed when rotation happens.
# ───────────────────────────────────────────────────────────────────────
