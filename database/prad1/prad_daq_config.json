{
    "_comment": "DAQ configuration for original PRad experiment — Fastbus ADC1881M readout",

    "adc_format": "adc1881m",
    "sparsify_sigma": 5.0,

    "event_tags": {
        "_comment": "PRad uses CODA2 event tags: 0x81 = physics, 0xC1 = sync",
        "physics":      ["0x81"],
        "prestart":     "0x11",
        "go":           "0x12",
        "end":          "0x20",
        "sync":         "0xC1",
        "epics":        "0x1F"
    },

    "bank_tags": {
        "_comment": "PRad bank tags. ADC1881M Fastbus data in 0xE120.",
        "adc1881m":        "0xE120",
        "ti_data":         "0xE10A",
        "trigger_bank":    "0xC000",
        "daq_config":      "0xE10E",
        "epics_data":      "0xE114"
    },

    "ti_format": {
        "_comment": "PRad TI bank: 9 words. Trigger type in data[2]>>24, timestamp in data[4..5].",
        "time_low_word":      4,
        "time_high_word":     5,
        "time_high_mask":     "0xFFFF",
        "time_high_shift":    0,
        "trigger_type_word":  2,
        "trigger_type_shift": 24,
        "trigger_type_mask":  "0xFF"
    },

    "trigger_bank": {
        "event_number_word": 0,
        "event_type_word":   1
    },

    "roc_tags": [
        {"tag": "0x01", "name": "PRadTS",    "crate": 1},
        {"tag": "0x04", "name": "PRadROC_1", "crate": 4},
        {"tag": "0x05", "name": "PRadROC_2", "crate": 5},
        {"tag": "0x06", "name": "PRadROC_3", "crate": 6}
    ],

    "ti_master_tag": "0x01",

    "pedestal_file": "prad1/adc1881m_pedestals.json",
    "daq_map_file": "prad1/prad_daq_map.json"
}
